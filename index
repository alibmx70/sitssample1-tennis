                { id: "p2", name: "Carlos Alcaraz", rating: 9.3, wins: 10, losses: 4, skillLevel: "Pro", last5: [{ vs: "Novak Djokovic", result: "Loss 1-2", date: "2026-05-01" }, { vs: "Jannik Sinner", result: "Win 2-0", date: "2026-04-27" }, { vs: "Daniil Medvedev", result: "Win 2-1", date: "2026-04-23" }, { vs: "Holger Rune", result: "Win 2-0", date: "2026-04-19" }, { vs: "Andrey Rublev", result: "Win 2-1", date: "2026-04-16" }] },
                { id: "p3", name: "Emma Raducanu", rating: 4.6, wins: 5, losses: 7, skillLevel: "Intermediate", last5: [{ vs: "Elena Rybakina", result: "Loss 0-2", date: "2026-05-01" }, { vs: "Leylah Fernandez", result: "Win 2-1", date: "2026-04-28" }, { vs: "Belinda Bencic", result: "Loss 1-2", date: "2026-04-24" }, { vs: "Karolina Muchova", result: "Win 2-1", date: "2026-04-20" }, { vs: "Maria Sakkari", result: "Loss 0-2", date: "2026-04-17" }] },
                { id: "p4", name: "Iga Swiatek", rating: 9.4, wins: 14, losses: 2, skillLevel: "Pro", last5: [{ vs: "Aryna Sabalenka", result: "Win 2-0", date: "2026-05-02" }, { vs: "Elena Rybakina", result: "Win 2-1", date: "2026-04-29" }, { vs: "Coco Gauff", result: "Win 2-0", date: "2026-04-25" }, { vs: "Jessica Pegula", result: "Win 2-0", date: "2026-04-22" }, { vs: "Ons Jabeur", result: "Loss 0-2", date: "2026-04-18" }] }
            ];
            localStorage.setItem(STORAGE_PLAYERS, JSON.stringify(players));
        }
        if (!localStorage.getItem(STORAGE_MATCHES)) {
            const matches = [
                { id: "m1", home: "Novak Djokovic", away: "Carlos Alcaraz", date: "2026-05-25", time: "18:00", court: "Center Court", status: "upcoming", winner: null, loser: null, resultText: null },
                { id: "m2", home: "Iga Swiatek", away: "Emma Raducanu", date: "2026-05-27", time: "16:30", court: "Court 1", status: "upcoming", winner: null, loser: null, resultText: null }
            ];
            localStorage.setItem(STORAGE_MATCHES, JSON.stringify(matches));
        }
        if (!localStorage.getItem(STORAGE_LEAGUES)) {
            localStorage.setItem(STORAGE_LEAGUES, JSON.stringify([{ id: "lg1", name: "🏆 ULTIMATE ORANGE LEAGUE", season: "Summer 2026" }]));
        }
        if (!localStorage.getItem(STORAGE_TOURNAMENTS)) {
            localStorage.setItem(STORAGE_TOURNAMENTS, JSON.stringify([
                { id: "t1", name: "Wimbledon Open", trophy: "🏆 Golden Racket", date: "2026-06-15", status: "upcoming" }
            ]));
        }
        if (!localStorage.getItem(STORAGE_GROUP_CHAT)) {
            localStorage.setItem(STORAGE_GROUP_CHAT, JSON.stringify([
                { id: "gc1", user: "Alex Coach", msg: "Welcome to Ultimate League! 🔥", timestamp: Date.now() }
            ]));
        }
        if (!localStorage.getItem(STORAGE_PRIVATE_CHAT)) {
            localStorage.setItem(STORAGE_PRIVATE_CHAT, JSON.stringify([]));
        }
        if (!localStorage.getItem(STORAGE_CHALLENGES)) {
            localStorage.setItem(STORAGE_CHALLENGES, JSON.stringify([]));
