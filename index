<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <title>Tennis Ultimate League • Full Admin + Register</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            background: radial-gradient(circle at 10% 20%, #0A192F, #061220);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
        }

        .phone {
            max-width: 460px;
            width: 100%;
            height: 800px;
            background: rgba(255, 255, 255, 0.98);
            border-radius: 56px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4), 0 0 0 8px rgba(255, 107, 53, 0.25);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            animation: floatIn 0.5s ease-out;
        }

        @keyframes floatIn {
            from { opacity: 0; transform: translateY(40px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .premium-header {
            background: linear-gradient(145deg, #0A192F, #0F2E42);
            padding: 20px 18px 16px;
            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .logo h1 {
            font-size: 1.3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FF6B35, #FFB347);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .user-card-header {
            background: rgba(255, 107, 53, 0.2);
            backdrop-filter: blur(12px);
            padding: 5px 12px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .rating-badge {
            background: #FF6B35;
            color: #0A192F;
            padding: 3px 10px;
            border-radius: 40px;
            font-weight: bold;
            font-size: 0.65rem;
        }

        .logout-btn {
            background: rgba(255, 107, 53, 0.2);
            border: 1px solid #FF6B35;
            color: #FFB347;
            padding: 5px 12px;
            border-radius: 40px;
            font-size: 0.65rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 16px 14px 80px;
            scroll-behavior: smooth;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 28px;
            padding: 16px;
            margin-bottom: 16px;
            box-shadow: 0 8px 28px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(255, 107, 53, 0.25);
            transition: transform 0.25s ease;
            animation: fadeSlideUp 0.4s ease-out;
        }

        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: 800;
            color: #0A192F;
            border-left: 5px solid #FF6B35;
            padding-left: 12px;
            margin-bottom: 14px;
        }

        .user-list-premium {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 16px;
        }

        .user-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #F8FAFF;
            border-radius: 60px;
            padding: 6px 10px;
            border: 1px solid #E2E8F0;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, #FF6B35, #FFB347);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1rem;
            color: white;
        }

        .user-details h4 {
            font-size: 0.85rem;
            color: #0A192F;
        }

        .user-details p {
            font-size: 0.65rem;
            color: #FF6B35;
        }

        .action-buttons {
            display: flex;
            gap: 6px;
        }

        .chat-btn, .challenge-btn {
            padding: 6px 12px;
            border-radius: 40px;
            font-size: 0.65rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
        }

        .chat-btn {
            background: #0A192F;
            color: white;
        }

        .challenge-btn {
            background: linear-gradient(135deg, #FF6B35, #E85D2C);
            color: white;
        }

        .chat-window {
            background: #F8FAFF;
            border-radius: 24px;
            padding: 12px;
            margin-top: 12px;
        }

        .chat-messages {
            max-height: 250px;
            overflow-y: auto;
            margin-bottom: 10px;
            padding: 6px;
        }

        .msg-bubble {
            background: white;
            padding: 8px 12px;
            border-radius: 20px;
            margin-bottom: 8px;
            border-left: 4px solid #FF6B35;
            font-size: 0.75rem;
        }

        .input-row {
            display: flex;
            gap: 8px;
        }

        .input-row input {
            flex: 1;
            padding: 10px;
            border-radius: 60px;
            border: 1px solid #E2E8F0;
        }

        .back-btn {
            background: transparent;
            border: 1px solid #FF6B35;
            color: #FF6B35;
            margin-bottom: 10px;
            padding: 6px 14px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.7rem;
        }

        .challenge-request {
            background: #FFF4E6;
            border-left: 4px solid #FF6B35;
            padding: 10px;
            border-radius: 16px;
            margin-bottom: 10px;
            font-size: 0.75rem;
        }

        .elegant-table {
            width: 100%;
            border-collapse: collapse;
        }

        .elegant-table th, .elegant-table td {
            padding: 8px 4px;
            text-align: left;
            border-bottom: 1px solid #EDF2F7;
            font-size: 0.7rem;
        }

        .forfeit-btn {
            background: #DC2626;
            background: linear-gradient(135deg, #DC2626, #B91C1C);
            padding: 5px 10px;
            border-radius: 40px;
            font-size: 0.65rem;
            color: white;
            border: none;
            cursor: pointer;
        }

        .bottom-nav-premium {
            position: absolute;
            bottom: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            display: flex;
            justify-content: space-around;
            padding: 6px 12px 20px;
            border-top: 1px solid rgba(255, 107, 53, 0.4);
        }

        .nav-icon-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            font-size: 0.65rem;
            font-weight: 600;
            color: #64748B;
            cursor: pointer;
            padding: 5px 10px;
            border-radius: 60px;
            transition: all 0.2s;
        }

        .nav-icon-btn.active {
            color: #FF6B35;
            background: #FFF1E6;
            transform: translateY(-2px);
        }

        /* Login & Register */
        .login-container, .register-container {
            background: linear-gradient(145deg, #FFFFFF, #FFF9F5);
            border-radius: 56px;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 24px 20px;
            overflow-y: auto;
        }

        .tennis-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #FF6B35, #FFB347);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            box-shadow: 0 10px 25px rgba(255, 107, 53, 0.3);
            animation: bounce 2s ease-in-out infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        .tennis-icon span { font-size: 2.5rem; }

        .login-header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FF6B35, #E85D2C);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }

        .login-header p {
            color: #FF8C5A;
            font-weight: 500;
            font-size: 0.8rem;
            text-align: center;
        }

        .input-group-login {
            margin-bottom: 14px;
        }

        .input-group-login input, .input-group-login select {
            width: 100%;
            padding: 12px 16px;
            background: #F8FAFF;
            border: 2px solid #FFE4D6;
            border-radius: 60px;
            font-size: 0.85rem;
        }

        .input-group-login input:focus, .input-group-login select:focus {
            outline: none;
            border-color: #FF6B35;
        }

        .login-btn {
            width: 100%;
            background: linear-gradient(135deg, #FF6B35, #E85D2C);
            padding: 12px;
            border-radius: 60px;
            font-size: 0.9rem;
            font-weight: 700;
            color: white;
            border: none;
            cursor: pointer;
            margin-top: 8px;
        }

        .toggle-auth {
            text-align: center;
            margin-top: 16px;
            font-size: 0.75rem;
            color: #FF6B35;
            cursor: pointer;
        }

        .demo-accounts {
            background: #FFF9F5;
            border-radius: 28px;
            padding: 12px;
            margin-top: 16px;
        }

        .demo-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: center;
            margin-top: 8px;
        }

        .demo-item {
            background: white;
            padding: 6px 10px;
            border-radius: 40px;
            font-size: 0.6rem;
            color: #0A192F;
            border: 1px solid #FFE4D6;
            cursor: pointer;
        }

        .trophy-icon {
            font-size: 1.2rem;
        }
    </style>
</head>
<body>
<div class="phone" id="appRoot"></div>

<script>
