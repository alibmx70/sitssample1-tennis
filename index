                { email: "carlos@tennis.com", password: "carlos123", role: "user", name: "Carlos Alcaraz", firstName: "Carlos", lastName: "Alcaraz", phone: "+34123456", location: "Murcia", skillLevel: "Pro", rating: 9.3, avatar: "CA" }
